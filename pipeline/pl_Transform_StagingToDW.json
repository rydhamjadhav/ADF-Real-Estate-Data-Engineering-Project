			{
				"name": "Lkp_Rowcount",
				"type": "Lookup",
				"dependsOn": [
					{
						"activity": "sp_LoadFactLeads",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.0:30:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "SELECT \n    (SELECT COUNT(*) FROM dwh.fact_Sales)    +\n    (SELECT COUNT(*) FROM dwh.fact_Leads)    +\n    (SELECT COUNT(*) FROM dwh.fact_Viewings) +\n    (SELECT COUNT(*) FROM dwh.fact_Offers)   AS [RowCount]",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_stg_Transactions",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "If_RowCountCheck",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "Lkp_Rowcount",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@greater(activity('Lkp_Rowcount').output.firstRow.RowCount, 0)",
						"type": "Expression"
					},
					"ifFalseActivities": [
						{
							"name": "FailEmptyFact",
							"type": "Fail",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"message": "Fact Table is Empty after Load",
								"errorCode": "EMPTY_FACT_TABLE"
							}
						},
						{
							"name": "sp_LogFailure_copy1",
							"type": "SqlServerStoredProcedure",
							"dependsOn": [
