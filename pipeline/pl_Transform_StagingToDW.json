										"type": "Int32"
									},
									"RowsLoaded": {
										"value": "0",
										"type": "Int32"
									},
									"RowsRejected": {
										"value": "0",
										"type": "Int32"
									},
									"Status": {
										"value": "Failed",
										"type": "String"
									},
									"ErrorMessage": {
										"value": "Pipeline 2 Failed",
										"type": "String"
									},
									"StartTime": {
										"value": "@{variables('PipelineStartTime')}",
										"type": "Datetime"
									},
									"EndTime": {
										"value": "@{utcNow()}",
										"type": "Datetime"
									}
								}
							},
							"linkedServiceName": {
								"referenceName": "ls_AzureSQL",
								"type": "LinkedServiceReference"
							}
						}
